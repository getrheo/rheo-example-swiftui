    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.59.0",
    "typescript": "^5.6.3",
    "tsup": "^8.5.1"
  },
  "description": "SwiftUI example app for RheoSwiftUI — config form + FlowView against the Rheo API"
