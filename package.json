{
  "name": "rheo-example-swiftui",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "node scripts/run-swiftui-example.mjs build",
    "run": "node scripts/run-swiftui-example.mjs run",
    "open": "open Package.swift",
    "verify": "node scripts/check-no-platform-contracts.mjs"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
